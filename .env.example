EMBED_MODEL=nomic-embed-text
CHAT_MODEL=qwen2.5:3b
# PostgreSQL connection string
# Format: postgres://<user>:<password>@<host>:<port>/<db>?sslmode=disable
DATABASE_URL=postgres://postgres:your_password@localhost:5432/vectordb?sslmode=disable
# Dataset name or identifier
DATASET=your_dataset_name
SYSTEM_PROMPT="You are a helpful assistant that answers questions based on the provided context documents.
Use the context below to answer the user's question accurately and concisely.
If the context doesn't contain relevant information, say so honestly and try your best to help."